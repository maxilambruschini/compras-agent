# ============================================================
# Compras Agent — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# --- Required (app refuses to start if missing) ---

# Postgres connection URL (for Docker Compose, use service name 'postgres')
DATABASE_URL=postgresql+asyncpg://compras:compras@postgres:5432/compras

# OpenAI API key for GPT-4o invoice extraction
OPENAI_API_KEY=sk-replace-me

# Meta WhatsApp Cloud API credentials
WHATSAPP_TOKEN=replace-me-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=replace-me-phone-number-id
WHATSAPP_VERIFY_TOKEN=replace-me-verify-token

# --- Optional (defaults shown) ---

DEBUG=false
LOG_LEVEL=INFO
CONFIDENCE_THRESHOLD=0.85

# --- Postgres Docker service config (used by docker-compose.yml) ---
POSTGRES_USER=compras
POSTGRES_PASSWORD=compras
POSTGRES_DB=compras
