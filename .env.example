# ============================================================
# Compras Agent — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# --- Postgres (Docker Compose uses the service name 'postgres') ---
POSTGRES_USER=compras
POSTGRES_PASSWORD=compras
POSTGRES_DB=compras
DATABASE_URL=postgresql+asyncpg://compras:compras@postgres:5432/compras

# --- OpenAI ---
OPENAI_API_KEY=sk-replace-me

# --- WhatsApp via Twilio ---
# Active provider. Only "twilio" is implemented; "meta" is a future stub.
WHATSAPP_PROVIDER=twilio

# Twilio Account SID — starts with "AC", found on console.twilio.com dashboard
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio Auth Token — found on console.twilio.com dashboard (click to reveal)
TWILIO_AUTH_TOKEN=replace-me-auth-token

# Twilio WhatsApp sender number — must include the "whatsapp:" prefix
# Use the sandbox number during testing: whatsapp:+14155238886
# Use your own approved number in production
TWILIO_FROM_NUMBER=whatsapp:+14155238886

# Public base URL of this server as seen by Twilio (for webhook signature validation).
# Required when running behind ngrok or a reverse proxy.
# Example: https://abc123.ngrok-free.app
# Leave blank when running locally without a tunnel (signature validation is skipped).
WEBHOOK_BASE_URL=

# --- Optional ---
DEBUG=false
LOG_LEVEL=INFO
CONFIDENCE_THRESHOLD=0.85
